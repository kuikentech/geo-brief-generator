# ─── NPM Security Configuration ───────────────────────────────────────────────
# Geo-Context Engineering Brief Generator — E4C AI Pilot Hackathon 2026
#
# SECURITY NOTE (2026-04-14):
# Following the axios supply chain attack (GTIG advisory, March 31 2026),
# axios versions 1.14.1 and 0.30.4 were found to include the malicious
# dependency "plain-crypto-js" (versions 4.2.0 / 4.2.1).
# This project is pinned to axios 1.15.0 (known-safe).
#
# save-exact prevents npm from writing "^" or "~" caret/tilde ranges
# when new packages are installed, ensuring reproducible installs.
save-exact=true

# Enforce the public npm registry — do not pull from private mirrors
# that may have cached the malicious packages.
registry=https://registry.npmjs.org/

# Audit level: fail install if moderate or higher vulnerabilities are found
# (remove/adjust if it blocks legitimate dev installs)
# audit-level=moderate
